<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="700.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.ThongTinCaNhan_Controller">
    <children>
        <AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f5f5f5;">
            <children>
                <AnchorPane prefHeight="60.0" prefWidth="500.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" AnchorPane.topAnchor="0.0">
                    <children>
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#quayLai" style="-fx-background-color: transparent; -fx-cursor: hand;" text="←" textFill="#ee4d2d">
                            <font> <Font name="System Bold" size="20.0" /> </font>
                        </Button>
                        <Label layoutX="210.0" layoutY="17.0" text="Sửa hồ sơ">
                            <font> <Font name="System Bold" size="18.0" /> </font>
                        </Label>
                    </children>
                </AnchorPane>

                <VBox alignment="CENTER" layoutY="60.0" prefHeight="120.0" prefWidth="500.0">
                    <children>
                        <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                            <image> <Image url="@images/user.png" /> </image>
                        </ImageView>
                    </children>
                </VBox>

                <VBox layoutY="180.0" prefWidth="500.0" spacing="15.0">
                    <padding> <Insets bottom="20.0" left="15.0" right="15.0" /> </padding>
                    <children>
                        <VBox style="-fx-background-color: white; -fx-background-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Tên"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtTen" text="Đang tải..." textFill="#999999"> <font> <Font size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#moSuaTieuSu" prefHeight="55.0" style="-fx-cursor: hand;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Tiểu sử"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtTieuSu" text="Thiết lập ngay" textFill="#aaaaaa">
                                            <font> <Font size="15.0" /> </font>
                                            <HBox.margin> <Insets right="10.0" /> </HBox.margin>
                                        </Label>
                                        <Label text="&gt;" textFill="#aaaaaa"> <font> <Font name="System Bold" size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox style="-fx-background-color: white; -fx-background-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#moSuaGioiTinh" prefHeight="55.0" style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0; -fx-cursor: hand;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Giới tính"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtGioiTinh" text="Thiết lập ngay" textFill="#ee4d2d">
                                            <font> <Font size="15.0" /> </font>
                                            <HBox.margin> <Insets right="10.0" /> </HBox.margin>
                                        </Label>
                                        <Label text="&gt;" textFill="#aaaaaa"> <font> <Font name="System Bold" size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" onMouseClicked="#moSuaNgaySinh" prefHeight="55.0" style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0; -fx-cursor: hand;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Ngày sinh"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtNgaySinh" text="Thiết lập ngay" textFill="#ee4d2d">
                                            <font> <Font size="15.0" /> </font>
                                            <HBox.margin> <Insets right="10.0" /> </HBox.margin>
                                        </Label>
                                        <Label text="&gt;" textFill="#aaaaaa"> <font> <Font name="System Bold" size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-cursor: hand;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Thông tin cá nhân"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="&gt;" textFill="#aaaaaa"> <font> <Font name="System Bold" size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox style="-fx-background-color: white; -fx-background-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Số điện thoại"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtSDT" text="Đang tải..." textFill="#999999"> <font> <Font size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Email"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="txtEmail" text="Đang tải..." textFill="#999999"> <font> <Font size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-cursor: hand;">
                                    <padding> <Insets left="15.0" right="15.0" /> </padding>
                                    <children>
                                        <Label text="Tài khoản liên kết"> <font> <Font size="15.0" /> </font> </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="&gt;" textFill="#aaaaaa"> <font> <Font name="System Bold" size="15.0" /> </font> </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="lopPhuMoc" style="-fx-background-color: rgba(0,0,0,0.5);" visible="false">
            <children>
                <Button mnemonicParsing="false" onAction="#dongPopup" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

                <StackPane style="-fx-background-color: white; -fx-background-radius: 15 15 0 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <padding> <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /> </padding>
                    <children>

                        <VBox fx:id="boxTieuSu" spacing="20.0" visible="false">
                            <children>
                                <Label text="Chỉnh sửa tiểu sử" textFill="#4a4a4a"> <font> <Font name="System Bold" size="18.0" /> </font> </Label>
                                <TextField fx:id="inputTieuSu" prefHeight="45.0" promptText="Nhập tiểu sử..." style="-fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-color: transparent;"> <font> <Font size="15.0" /> </font> </TextField>
                                <Button mnemonicParsing="false" onAction="#luuTieuSu" prefHeight="45.0" prefWidth="500.0" style="-fx-background-color: #ee4d2d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Lưu"> <font> <Font name="System Bold" size="16.0" /> </font> </Button>
                            </children>
                        </VBox>

                        <VBox fx:id="boxGioiTinh" spacing="10.0" visible="false">
                            <fx:define> <ToggleGroup fx:id="nhomGioiTinh" /> </fx:define>
                            <children>
                                <Label text="Chọn giới tính" textFill="#4a4a4a"> <font> <Font name="System Bold" size="18.0" /> </font> <VBox.margin> <Insets bottom="10.0" /> </VBox.margin> </Label>
                                <RadioButton fx:id="rdoNam" mnemonicParsing="false" prefHeight="40.0" style="-fx-cursor: hand;" text=" Nam" toggleGroup="$nhomGioiTinh"> <font> <Font size="15.0" /> </font> </RadioButton>
                                <RadioButton fx:id="rdoNu" mnemonicParsing="false" prefHeight="40.0" style="-fx-cursor: hand;" text=" Nữ" toggleGroup="$nhomGioiTinh"> <font> <Font size="15.0" /> </font> </RadioButton>
                                <RadioButton fx:id="rdoKhac" mnemonicParsing="false" prefHeight="40.0" style="-fx-cursor: hand;" text=" Khác" toggleGroup="$nhomGioiTinh"> <font> <Font size="15.0" /> </font> </RadioButton>
                                <Button mnemonicParsing="false" onAction="#luuGioiTinh" prefHeight="45.0" prefWidth="500.0" style="-fx-background-color: #ee4d2d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Lưu">
                                    <font> <Font name="System Bold" size="16.0" /> </font>
                                    <VBox.margin> <Insets top="10.0" /> </VBox.margin>
                                </Button>
                            </children>
                        </VBox>

                        <VBox fx:id="boxNgaySinh" spacing="20.0" visible="false">
                            <children>
                                <Label text="Chọn ngày sinh" textFill="#4a4a4a"> <font> <Font name="System Bold" size="18.0" /> </font> </Label>
                                <DatePicker fx:id="dpNgaySinh" prefHeight="45.0" prefWidth="500.0" promptText="dd/mm/yyyy" style="-fx-font-size: 15px;" />
                                <Button mnemonicParsing="false" onAction="#luuNgaySinh" prefHeight="45.0" prefWidth="500.0" style="-fx-background-color: #ee4d2d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Lưu"> <font> <Font name="System Bold" size="16.0" /> </font> </Button>
                            </children>
                        </VBox>

                    </children>
                </StackPane>
            </children>
        </AnchorPane>
    </children>
</StackPane>