<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #F8F5F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.Primary_Controller">
    <children>
      
        <StackPane prefHeight="200.0" prefWidth="500.0" style="-fx-background-color: #FFFDE7;">
            <children>
                <ImageView fx:id="bannerImage" fitHeight="150.0" fitWidth="340.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/anh1.png" />
                    </image>
                </ImageView>
                <Button mnemonicParsing="false" onAction="#clickVaoIconTaiKhoan" style="-fx-background-radius: 100; -fx-cursor: hand; -fx-background-color: transperent;" StackPane.alignment="TOP_RIGHT">
                    <StackPane.margin>
                        <Insets right="10.0" top="10.0" />
                    </StackPane.margin>
                    <graphic>
                        <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/profile.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </StackPane>

        <Button fx:id="btnThongTin" mnemonicParsing="false" onAction="#chuyenTrangThongTin" prefHeight="60.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to bottom right, #D4A373, #A47148); -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(164, 113, 72, 0.4), 15, 0, 5, 5); -fx-text-fill: white;" text="Thông tin doanh nghiệp">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Button>
      
        <Button fx:id="btnNguyenLieuTho" mnemonicParsing="false" onAction="#vaoNguyenLieuTho" prefHeight="60.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to bottom right, #D4A373, #A47148); -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(164, 113, 72, 0.4), 15, 0, 5, 5); -fx-text-fill: white;" text="Nguyên liệu thô">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Button>
      
        <Button fx:id="btnNguyenLieuSoChe" mnemonicParsing="false" onAction="#vaoNguyenLieuSoChe" prefHeight="60.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to bottom right, #D4A373, #A47148); -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(164, 113, 72, 0.4), 15, 0, 5, 5); -fx-text-fill: white;" text="Nguyên liệu sơ chế">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Button>
      
        <Button fx:id="btnFoodDrink" mnemonicParsing="false" onAction="#vaoFoodAndDrink" prefHeight="60.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to bottom right, #D4A373, #A47148); -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(164, 113, 72, 0.4), 15, 0, 5, 5); -fx-text-fill: white;" text="Food and Drink" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Button>
      
    </children>
    <padding>
        <Insets bottom="20.0" />
    </padding>
</VBox>
