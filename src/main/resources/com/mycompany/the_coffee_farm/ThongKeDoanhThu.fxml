<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.ThongKeDoanhThu_Controller">
   <children>
      <AnchorPane prefHeight="80.0" prefWidth="500.0" style="-fx-background-color: #0A3D62;">
         <children>
            <Button layoutX="10.0" layoutY="20.0" mnemonicParsing="false" onAction="#quayLai" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-cursor: hand;" text="←" />
            <Label layoutX="120.0" layoutY="22.0" text="THỐNG KÊ DOANH THU" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>

      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="100.0" spacing="10.0">
         <children>
            <Label text="☰ Tháng:" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <ComboBox fx:id="cboThang" onAction="#locDuLieu" prefHeight="35.0" prefWidth="110.0" style="-fx-font-size: 14; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
            
            <Label text=" Năm:" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <ComboBox fx:id="cboNam" onAction="#locDuLieu" prefHeight="35.0" prefWidth="100.0" style="-fx-font-size: 14; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
         </children>
      </HBox>

      <HBox layoutX="20.0" layoutY="155.0" spacing="20.0">
         <children>
            <VBox alignment="CENTER" prefHeight="80.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8;">
               <children>
                  <Label text="Tổng Doanh Thu" textFill="#7f8c8d">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblTongDoanhThu" text="0 đ" textFill="#27ae60">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="80.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8;">
               <children>
                  <Label text="Tổng Đơn Hàng" textFill="#7f8c8d">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblTongDonHang" text="0 Đơn" textFill="#2980b9">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>

      <TableView fx:id="tblThongKe" layoutX="20.0" layoutY="255.0" prefHeight="345.0" prefWidth="460.0" style="-fx-background-radius: 8;">
        <columns>
          <TableColumn fx:id="colTenSP" prefWidth="200.0" text="Tên Sản Phẩm" />
          <TableColumn fx:id="colSoLuong" prefWidth="100.0" text="Số Lượng Bán" />
          <TableColumn fx:id="colDoanhThu" prefWidth="158.0" text="Doanh Thu (VNĐ)" />
        </columns>
      </TableView>

      <Button layoutX="150.0" layoutY="620.0" mnemonicParsing="false" onAction="#xuatBaoCao" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 8; -fx-cursor: hand;" text="📥 Xuất Báo Cáo" />
   </children>
</AnchorPane>
