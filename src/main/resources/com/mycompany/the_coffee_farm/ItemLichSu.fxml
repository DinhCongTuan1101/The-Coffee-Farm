<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="450.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>
                <HBox spacing="15.0">
                    <children>
                        <ImageView fx:id="imgSanPham" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true" />
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="txtTenSP" maxWidth="Infinity" text="Tên Sản Phẩm" wrapText="true">
                                    <font> <Font name="System Bold" size="16.0" /> </font>
                                </Label>
                                <Label fx:id="txtSoLuong" alignment="CENTER_RIGHT" maxWidth="Infinity" text="x1" textFill="#757575" />
                                <Label fx:id="txtGiaTien" alignment="CENTER_RIGHT" maxWidth="Infinity" text="200,000đ" textFill="#ee4d2d" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <Separator />
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Region HBox.hgrow="ALWAYS" /> 
                        
                        <Label text="Thành tiền:" textFill="#333333">
                            <font> <Font size="14.0" /> </font>
                        </Label>
                        <Label fx:id="txtTongTien" text="200,000đ" textFill="#ee4d2d">
                            <font> <Font name="System Bold" size="18.0" /> </font>
                        </Label>
                        <Button fx:id="btnMuaLai" mnemonicParsing="false" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: white; -fx-border-color: #ee4d2d; -fx-border-radius: 5; -fx-background-radius: 5; -fx-text-fill: #ee4d2d; -fx-cursor: hand;" text="Mua lại">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>