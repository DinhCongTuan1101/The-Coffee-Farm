<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.DanhSachDiaChi_Controller">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="500.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" AnchorPane.topAnchor="0.0">
            <children>
                <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#quayLai" style="-fx-background-color: transparent; -fx-cursor: hand;" text="←" textFill="#ee4d2d">
                    <font> <Font name="System Bold" size="20.0" /> </font>
                </Button>
                <Label fx:id="txtTieuDe" layoutX="60.0" layoutY="17.0" text="Chọn địa chỉ nhận hàng">
                    <font> <Font name="System Bold" size="18.0" /> </font>
                </Label>
            </children>
        </AnchorPane>
        
        <ScrollPane fx:id="scrollPane" fitToWidth="true" layoutY="65.0" prefHeight="555.0" prefWidth="500.0" style="-fx-background: #f5f5f5; -fx-border-color: transparent;" AnchorPane.bottomAnchor="80.0" AnchorPane.topAnchor="65.0">
            <content>
                <VBox fx:id="vboxDanhSach" spacing="10.0" style="-fx-padding: 10;" />
            </content>
        </ScrollPane>

        <AnchorPane fx:id="paneXacNhan" prefHeight="80.0" prefWidth="500.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;" AnchorPane.bottomAnchor="0.0">
            <children>
                <Button layoutX="20.0" layoutY="15.0" mnemonicParsing="false" onAction="#xacNhanChon" prefHeight="50.0" prefWidth="460.0" style="-fx-background-color: #ee4d2d; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;" text="Xác Nhận">
                    <font> <Font name="System Bold" size="16.0" /> </font>
                </Button>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>