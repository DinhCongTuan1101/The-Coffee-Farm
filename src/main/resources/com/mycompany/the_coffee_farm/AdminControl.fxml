<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.AdminControl_Controller">
   <children>
      <AnchorPane prefHeight="160.0" prefWidth="500.0" style="-fx-background-color: #0A3D62; -fx-background-radius: 0 0 30 30;">
         <children>
            <Label layoutX="111.0" layoutY="44.0" text="TRANG QUẢN TRỊ" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label layoutX="183.0" layoutY="91.0" text="The Coffee Farm" textFill="#d1d8e0">
               <font>
                  <Font name="System Italic" size="18.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>

      <VBox layoutX="75.0" layoutY="200.0" prefHeight="400.0" prefWidth="350.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#moQuanLySanPham" prefHeight="65.0" prefWidth="350.0" style="-fx-background-color: #1F618D; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 18; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);;" text="📦 Quản lý Sản phẩm" />
            <Button mnemonicParsing="false" onAction="#moQuanLyDonHang" prefHeight="65.0" prefWidth="350.0" style="-fx-background-color: #1F618D; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 18; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);;" text="🛒 Quản lý Đơn hàng" />
            <Button mnemonicParsing="false" onAction="#moQuanLyTaiKhoan" prefHeight="65.0" prefWidth="350.0" style="-fx-background-color: #1F618D; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 18; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);;" text="👥 Quản lý Tài khoản" />
            <Button mnemonicParsing="false" onAction="#moThongKeDoanhThu" prefHeight="65.0" prefWidth="350.0" style="-fx-background-color: #1F618D; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 18; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);;" text="📊 Thống kê Doanh thu" />
         </children>
      </VBox>

      <Button layoutX="175.0" layoutY="620.0" mnemonicParsing="false" onAction="#dangXuat" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 16; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);;" text="Đăng xuất" />
   </children>
</AnchorPane>
