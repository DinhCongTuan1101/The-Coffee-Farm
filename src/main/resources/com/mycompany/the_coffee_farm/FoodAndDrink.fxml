<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" fx:id="khungFoodAndDrink" minWidth="500.0" prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #FFFDE7;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.FoodAndDrink_Controller">
    <children>
        <Button fx:id="btnBack" layoutX="15.0" layoutY="15.0" mnemonicParsing="false" onAction="#veTrangChu" prefHeight="51.0" prefWidth="73.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="←">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Button>
        <Label layoutX="101.0" layoutY="25.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Food And Drink" />
        
        <TextField fx:id="txtTimMon" layoutX="20.0" layoutY="75.0" onKeyReleased="#timKiem" prefHeight="42.0" prefWidth="460.0" promptText="Tìm món..." style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 25; -fx-border-width: 1; -fx-padding: 5 15 5 45; -fx-background-radius: 25; -fx-font-size: 15px;" />
        <ImageView fitHeight="20.0" fitWidth="20.0" layoutX="35.0" layoutY="86.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/loupe.png" />
            </image>
        </ImageView>

        <HBox alignment="CENTER" layoutX="20.0" layoutY="135.0" prefHeight="45.0" prefWidth="460.0" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#showDoUong" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 12; -fx-background-color: #00cec9; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 206, 201, 0.3), 8, 0, 0, 3);" text="🥤 Đồ Uống" />
                <Button mnemonicParsing="false" onAction="#showDoAn" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 12; -fx-background-color: #00cec9; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 206, 201, 0.3), 8, 0, 0, 3);" text="🍔 Đồ Ăn" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutY="200.0" prefHeight="500.0" prefWidth="500.0" style="-fx-background-color: transparent; -fx-background: #FFFDE7; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="-3.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="200.0">
            <content>
                <StackPane prefHeight="500.0" prefWidth="500.0" style="-fx-background-color: #FFFDE7;">
                    <children>
                        <VBox fx:id="vboxDoAn" alignment="TOP_CENTER" prefWidth="500.0" spacing="15.0" style="-fx-padding: 5 20 20 20;" />
                        
                        <VBox fx:id="vboxDoUong" alignment="TOP_CENTER" prefWidth="500.0" spacing="15.0" style="-fx-padding: 5 20 20 20;" />
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
