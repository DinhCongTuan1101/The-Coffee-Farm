<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.QuanLySanPham_Controller">
   <children>
      <AnchorPane prefHeight="80.0" prefWidth="500.0" style="-fx-background-color: #0A3D62;">
         <children>
            <Button layoutX="10.0" layoutY="20.0" mnemonicParsing="false" onAction="#quayLai" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-cursor: hand;" text="←" />
            <Label layoutX="123.0" layoutY="22.0" text="QUẢN LÝ SẢN PHẨM" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
         </children>
      </AnchorPane>

      <TableView fx:id="tblSanPham" layoutX="20.0" layoutY="127.0" prefHeight="230.0" prefWidth="460.0" style="-fx-background-radius: 8;">
        <columns>
          <TableColumn fx:id="colId" prefWidth="84.00000190734863" text="ID" />
          <TableColumn fx:id="colTen" prefWidth="227.19994354248047" text="Tên Sản Phẩm" />
          <TableColumn fx:id="colGia" prefWidth="148.0" text="Giá (VNĐ)" />
        </columns>
      </TableView>

      <TextField fx:id="txtTenSP" layoutX="20.0" layoutY="370.0" prefHeight="40.0" prefWidth="460.0" promptText="Nhập tên sản phẩm..." style="-fx-background-radius: 8; -fx-font-size: 14;" />
      <TextField fx:id="txtGiaSP" layoutX="20.0" layoutY="420.0" prefHeight="40.0" prefWidth="460.0" promptText="Nhập giá bán..." style="-fx-background-radius: 8; -fx-font-size: 14;" />

      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="470.0" prefHeight="95.0" prefWidth="460.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8;">
         <children>
            <AnchorPane prefHeight="80.0" prefWidth="80.0" style="-fx-border-color: #bdc3c7; -fx-background-color: #ecf0f1;">
               <children><ImageView fx:id="imgPreview" fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true" /></children>
            </AnchorPane>
            <VBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#chonAnh" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="📁 Chọn Ảnh..." />
                  <Label fx:id="lblTenAnh" text="Chưa chọn ảnh nào" textFill="#7f8c8d" />
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox layoutX="20.0" layoutY="580.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#themSP" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ Thêm" />
            <Button mnemonicParsing="false" onAction="#suaSP" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 8; -fx-cursor: hand;" text="✏ Sửa" />
            <Button mnemonicParsing="false" onAction="#xoaSP" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 8; -fx-cursor: hand;" text="🗑 Xóa" />
         </children>
      </HBox>
      <Button layoutX="20.0" layoutY="95.0" mnemonicParsing="false" onAction="#locTho" text="Nguyên liệu thô" />
      <Button layoutX="130.0" layoutY="95.0" mnemonicParsing="false" onAction="#locSoChe" text="Nguyên liệu sơ chế" />
      <Button layoutX="254.0" layoutY="95.0" mnemonicParsing="false" onAction="#locDoUong" text="Đồ uống" />
      <Button layoutX="324.0" layoutY="95.0" mnemonicParsing="false" onAction="#locDoAn" text="Đồ ăn" />

      <StackPane fx:id="paneThongBao" style="-fx-background-color: rgba(0,0,0,0.5);" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
          <children>
              <VBox alignment="CENTER" maxHeight="150" maxWidth="300" spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);">
                  <children>
                      <Label style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 16px;" text="THÔNG BÁO" />
                      <Label fx:id="lblNoiDungThongBao" style="-fx-font-size: 14px;" text="Nội dung" />
                      <Button onAction="#dongThongBao" prefWidth="80" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="OK" />
                  </children>
              </VBox>
          </children>
      </StackPane>
   </children>
</AnchorPane>
