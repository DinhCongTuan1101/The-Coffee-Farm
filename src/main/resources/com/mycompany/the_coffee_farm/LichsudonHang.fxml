<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #F8F5F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.LichsudonHang_Controller">
    <children>
        <AnchorPane prefHeight="60.0" prefWidth="500.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <children>
                <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#quayLaiAccount" style="-fx-background-color: transparent; -fx-cursor: hand;" text="←" textFill="#5d4037">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Button>
                <Label layoutX="160.0" layoutY="17.0" text="Lịch sử đơn hàng" textFill="#5d4037">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
        
        <ScrollPane fitToWidth="true" layoutY="65.0" prefHeight="635.0" prefWidth="500.0" style="-fx-background-color: transparent; -fx-background: #F8F5F0; -fx-border-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="65.0">
