<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #f7f7f7;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.TimKiemDonHang_Controller">
   <children>
      <Label layoutX="150.0" layoutY="17.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Tra cứu đơn hàng" />
      
      <TextField fx:id="txtSdtTraCuu" layoutX="20" layoutY="80" prefHeight="50" prefWidth="460" promptText="Nhập số điện thoại của bạn..." style="-fx-background-radius: 10; -fx-padding: 0 15; -fx-font-size: 15px;" />
      <Button layoutX="380" layoutY="87" onAction="#xuLyTimKiem" prefHeight="36" prefWidth="90" style="-fx-background-color: linear-gradient(to bottom right, #D4A373, #A47148); -fx-text-fill: white; -fx-background-radius: 8;" text="Tìm kiếm">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>

      <ScrollPane hbarPolicy="NEVER" layoutY="149.0" prefHeight="551.0" prefWidth="500.0" style="-fx-background-color: transparent;">
         <content>
            <VBox fx:id="vboxDanhSachDon" prefWidth="440" spacing="15" style="-fx-padding: 10;" />
         </content>
      </ScrollPane>
      <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#quayLaiAccount" prefHeight="20.0" prefWidth="62.0" style="-fx-background-color: transparent;" text="←">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
